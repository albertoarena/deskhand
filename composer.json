{
    "name": "albertoarena/deskhand",
    "description": "Isolated, test-passing Laravel environments per worktree, for running parallel AI coding agents.",
    "type": "library",
    "keywords": [
        "laravel",
        "worktree",
        "cli",
        "testing",
        "ai-agents",
        "isolation",
        "parallel"
    ],
    "homepage": "https://github.com/albertoarena/deskhand",
    "license": "MIT",
    "authors": [
        {
            "name": "Alberto Arena",
            "email": "arena.alberto@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Deskhand\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deskhand\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/deskhand"
    ],
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
