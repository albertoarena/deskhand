#!/usr/bin/env php
<?php

/*
 * deskhand console entrypoint.
 *
 * The PHP version guard runs FIRST, before the autoloader and before any
 * 8.3-only syntax executes, so an unsupported runtime gets a friendly message
 * rather than a parse error or stack trace (see implementation.md §2). Keep
 * this bootstrap file free of PHP 8.3+ syntax for the same reason.
 */

if (PHP_VERSION_ID < 80300) {
    fwrite(STDERR, sprintf(
        'deskhand requires PHP 8.3 or newer. You are running PHP %s.'.PHP_EOL,
        PHP_VERSION
    ));

    exit(1);
}

$autoloaders = [
    __DIR__.'/../vendor/autoload.php',   // local clone / PHAR
    __DIR__.'/../../../autoload.php',     // installed as a Composer dependency
];

$autoloaderLoaded = false;
foreach ($autoloaders as $autoloader) {
    if (is_file($autoloader)) {
        require $autoloader;
        $autoloaderLoaded = true;
        break;
    }
}

if (! $autoloaderLoaded) {
    fwrite(STDERR, 'deskhand: could not locate the Composer autoloader. Run "composer install".'.PHP_EOL);

    exit(1);
}

exit((new Deskhand\Console\Application)->run());
